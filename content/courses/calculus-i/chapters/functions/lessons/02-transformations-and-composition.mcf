type: multiple_choice
prompt: |
  Which expression shifts $f(x)$ three units to the right?
options:
  - id: a
    text: "f(x)+3"
  - id: b
    text: "f(x-3)"
  - id: c
    text: "f(3x)"

answer: b
hint: "Review the key rule in the notes."
explanation: "The selected answer follows directly from the definition or rule above."
```

